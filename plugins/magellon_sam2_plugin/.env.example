# SAM2 Particle Picker Plugin — environment variables
# Copy to .env and fill in values before running locally.

APP_ENV=development

# Plugin HTTP endpoint — advertised to CoreService for SYNC/PREVIEW dispatch.
# Must be reachable from the CoreService container/host.
MAGELLON_PLUGIN_HTTP_ENDPOINT=http://localhost:8015

# Optional: override host/port separately (MAGELLON_PLUGIN_HTTP_ENDPOINT takes precedence)
# MAGELLON_PLUGIN_HOST=localhost
# MAGELLON_PLUGIN_PORT=8015

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=behd1d2
RABBITMQ_VHOST=/

# Where SAM2 downloads model weights (defaults to /app/weights in Docker)
SAM2_WEIGHTS_DIR=/app/weights

# Step-event streaming (optional; set 0 to disable)
MAGELLON_STEP_EVENTS_ENABLED=1
MAGELLON_STEP_EVENTS_RMQ=1
